{
  "headers": [
    {
      "source": "/",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ],
  "rewrites": [
    { "source": "/calendar", "destination": "/index.html" },
    { "source": "/calendar/", "destination": "/index.html" },
    { "source": "/gestao", "destination": "/index.html" },
    { "source": "/gestao/", "destination": "/index.html" },
    { "source": "/gestao/:path*", "destination": "/index.html" },
    { "source": "/jogos/:path*", "destination": "/index.html" },
    { "source": "/login", "destination": "/index.html" },
    { "source": "/register", "destination": "/index.html" },
    { "source": "/reset-password", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/admin/:path*", "destination": "/index.html" },
    { "source": "/team", "destination": "/index.html" },
    { "source": "/team/", "destination": "/index.html" },
    { "source": "/history", "destination": "/index.html" },
    { "source": "/history/", "destination": "/index.html" },
    { "source": "/complete-profile", "destination": "/index.html" },
    { "source": "/complete-profile/", "destination": "/index.html" },
    { "source": "/bootstrap", "destination": "/index.html" },
    { "source": "/bootstrap/", "destination": "/index.html" }
  ]
}
